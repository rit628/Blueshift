task modifyElement(list<int> x) {
    x[2] = 9;
}

task printElement(list<int> x) {
    print(x[3]);
}

task checkElementEquality(list<int> x) {
    print(x[2] == 2);
    print(x[2] != 2);
    print(!(x[2] == 2));
}

task checkContainerEquality(list<int> x) {
    print(x == [0, 1, 2, 3]);
    print(x != [0, 1, 2, 3]);
    print(!(x == [0, 1, 2, 3]));
}

task appendElement(list<int> x) {
    x.append(4);
    print(x);
}

task printRow(list<list<int>> y) {
    print(y[1]);
}

task printEntry(list<list<int>> y) {
    print(y[1][3]);
}

task accessRow(list<list<int>> y) {
    list<int> row = y[0];
    row[1] = 8;
    print(row);
}

task accessDevice(list<TIMER_TEST> z) {
    virtual TIMER_TEST t1;
    virtual TIMER_TEST t2;
    t1.test_val = 4;
    t2.test_val = 8;
    z = [t1, t2];
    print(z[0].test_val);
}

setup() {
    virtual list<int> X = [0, 1, 2, 3];
    modifyElement(X);
    printElement(X);
    checkElementEquality(X);
    checkContainerEquality(X);
    appendElement(X);

    virtual list<list<int>> Y = [[0, 1, 2, 3], [4, 5, 6, 7]];
    printRow(Y);
    printEntry(Y);
    accessRow(Y);

    virtual list<TIMER_TEST> Z;
    accessDevice(Z);
}